<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Discount_Reason_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Discount_Percent__c &gt; 10, ISBLANK(Discount_Reason__c))</errorConditionFormula>
    <errorDisplayField>Discount_Reason__c</errorDisplayField>
    <errorMessage>Discount reason is required when discount is above 10%.</errorMessage>
</ValidationRule>
